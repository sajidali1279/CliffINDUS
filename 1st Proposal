Step 3: User Roles & Features
Role	Can See/Do
Consumer	View products by location, add to cart, checkout, track order, support
Retailer	Buy from wholesalers only, sell to consumers, manage inventory, dashboards
Wholesaler	Sell to retailers only, manage stock, set quantities, expiry, shelves
Admin	Manage users, view analytics, support tickets, inventory monitoring

Important: We need role-based filtering so users see only the products relevant to their role.

Step 4: Database Models (Initial Plan)
#Users:
class User(AbstractUser):
    ROLE_CHOICES = [
        ('consumer', 'Consumer'),
        ('retailer', 'Retailer'),
        ('wholesaler', 'Wholesaler'),
        ('admin', 'Admin'),
    ]
    role = models.CharField(max_length=20, choices=ROLE_CHOICES)
    location = models.PointField(null=True, blank=True)  # For geo queries
#Products:
class Product(models.Model):
    name = models.CharField(max_length=200)
    description = models.TextField()
    price = models.DecimalField(max_digits=10, decimal_places=2)
    quantity = models.IntegerField()
    threshold = models.IntegerField(default=10)
    expiry_date = models.DateField(null=True, blank=True)
    shelf_number = models.CharField(max_length=50, blank=True)
    show_shelf = models.BooleanField(default=False)
    owner = models.ForeignKey(User, on_delete=models.CASCADE)  # Wholesaler or retailer
    allowed_roles = models.JSONField()  # ['consumer'], ['retailer'], etc.
# Orders/Cart
class Order(models.Model):
    user = models.ForeignKey(User, on_delete=models.CASCADE)
    products = models.ManyToManyField(Product, through='OrderItem')
    status = models.CharField(choices=[('pending','Pending'),('completed','Completed')])
    total_amount = models.DecimalField(max_digits=10, decimal_places=2)
    created_at = models.DateTimeField(auto_now_add=True)

class OrderItem(models.Model):
    order = models.ForeignKey(Order, on_delete=models.CASCADE)
    product = models.ForeignKey(Product, on_delete=models.CASCADE)
    quantity = models.IntegerField()

